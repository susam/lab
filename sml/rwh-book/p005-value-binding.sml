val a = 10 : int
val b : int = 20
val c : int = 30 : int
val _ = print ("a: " ^ Int.toString a ^
               "; b: " ^ Int.toString b ^
               "; c: " ^ Int.toString c ^ "\n")

val aa = 10 : int
and bb : int = 20
and cc : int = 30 : int

val _ = print ("aa: " ^ Int.toString aa ^
               "; bb: " ^ Int.toString bb ^
               "; cc: " ^ Int.toString cc ^ "\n")

val aa : real = 2.0
val _ = print ("aa: " ^ Real.toString aa ^ "\n")
